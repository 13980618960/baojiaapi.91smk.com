NODE_ENV=development

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=baojia
DB_USER=root
DB_PASSWORD=your_password_here

# JWT配置
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_EXPIRES_IN=7d

# Redis配置(可选)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# 上传配置
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# 微信小程序配置
WECHAT_APPID=your_appid
WECHAT_APPSECRET=your_appsecret

# 宝塔环境
PORT=3000
HOST=0.0.0.0
